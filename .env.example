# Anthropic API key for direct API calls (used by llm.py for question detection)
# Get your key from: https://console.anthropic.com/settings/keys
# Note: Uses SOFTFOUNDRY_ prefix to avoid conflicts with Claude Agent SDK
SOFTFOUNDRY_ANTHROPIC_API_KEY=

# OAuth token for Claude Code SDK (more cost-effective than API key)
# Generate a long-lived token by running: claude --setup-token
# Note: Uses SOFTFOUNDRY_ prefix to avoid conflicts with system environment
SOFTFOUNDRY_CLAUDE_CODE_OAUTH_TOKEN=
